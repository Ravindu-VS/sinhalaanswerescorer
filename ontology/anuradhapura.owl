<owl:NamedIndividual rdf:about="#Anuradhapura">
  <rdf:type rdf:resource="#Location"/>
  <significance_si rdf:datatype="http://www.w3.org/2001/XMLSchema#string">අනුරාධපුරය - ශ්‍රී ලංකාවේ පළමු අගනුවර</significance_si>
