  <ruled_during rdf:resource="#EarlyPeriod_377BCE_to_100CE"/>
  <reign_start rdf:datatype="http://www.w3.org/2001/XMLSchema#string">437 BCE</reign_start>
  <reign_end rdf:datatype="http://www.w3.org/2001/XMLSchema#string">367 BCE</reign_end>
