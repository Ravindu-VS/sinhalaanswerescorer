</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Devanampiya_Tissa">
  <rdf:type rdf:resource="#Ruler"/>
  <ruled_during rdf:resource="#EarlyPeriod_377BCE_to_100CE"/>
  <reign_start rdf:datatype="http://www.w3.org/2001/XMLSchema#string">247 BCE</reign_start>
  <reign_end rdf:datatype="http://www.w3.org/2001/XMLSchema#string">207 BCE</reign_end>
  <significance_si rdf:datatype="http://www.w3.org/2001/XMLSchema#string">දේවානම්පිය තිස්ස - බුදුදහම රාජ්‍ය ආගම කළ රජු</significance_si>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Dutugemunu">
