  <reign_end rdf:datatype="http://www.w3.org/2001/XMLSchema#string">137 BCE</reign_end>
  <significance_si rdf:datatype="http://www.w3.org/2001/XMLSchema#string">දුටුගැමුණු - ලංකාව එක්සේසත් කළ වීර රජු</significance_si>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Vattagamani_Abhaya">
  <rdf:type rdf:resource="#Ruler"/>
  <reign_start rdf:datatype="http://www.w3.org/2001/XMLSchema#string">29 BCE</reign_start>
  <reign_end rdf:datatype="http://www.w3.org/2001/XMLSchema#string">17 BCE</reign_end>
  <significance_si rdf:datatype="http://www.w3.org/2001/XMLSchema#string">වට්ටගාමිණී අභය - අභයගිරිය ස්ථාපකයා</significance_si>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Vasabha">
  <rdf:type rdf:resource="#Ruler"/>
  <ruled_during rdf:resource="#MiddlePeriod_100CE_to_500CE"/>
  <reign_start rdf:datatype="http://www.w3.org/2001/XMLSchema#string">67 CE</reign_start>
  <reign_end rdf:datatype="http://www.w3.org/2001/XMLSchema#string">111 CE</reign_end>
